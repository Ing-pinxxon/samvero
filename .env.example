# Base de datos PostgreSQL
# - Producción: la crea Vercel (Storage → Postgres, con Neon). Vercel te da la
#   variable DATABASE_URL automáticamente al conectarla a tu proyecto.
# - Local: puedes usar la MISMA base de Vercel/Neon (funciona desde cualquier
#   equipo por internet) o instalar Postgres local.
DATABASE_URL="postgresql://usuario:clave@host/samvero?sslmode=require"

# Almacenamiento de imágenes en producción serverless (Vercel Blob).
# Se genera automáticamente al activar Blob en el panel de Vercel. En local se deja vacío
# (las imágenes se guardan en public/uploads).
BLOB_READ_WRITE_TOKEN=""

# Admin (para el panel /admin)
ADMIN_EMAIL="admin@samvero.co"
# Opción simple para desarrollo local: contraseña en texto plano.
# ⚠️ NUNCA pongas aquí tu contraseña real: este archivo se sube a GitHub.
ADMIN_PASSWORD="cambia-esta-clave-local"
# Opción segura para producción: hash bcrypt (si está presente, tiene prioridad sobre ADMIN_PASSWORD).
# Genera uno con: node scripts/hash-password.mjs "tuClave"
ADMIN_PASSWORD_HASH=""
# Secreto para firmar el JWT de sesión (usa una cadena larga y aleatoria)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-o-mas-caracteres"

# WhatsApp de la tienda (formato internacional sin +, ej. 57 = Colombia)
NEXT_PUBLIC_WHATSAPP_NUMBER="573214496014"

# URL pública del sitio
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
